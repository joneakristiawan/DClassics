<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".activities.BooksDetailsActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/blueHeader"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/secondary_blue"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary_background"
            android:paddingTop="60dp"
            app:layout_constraintTop_toBottomOf="@id/blueHeader">

            <!-- 1. Genre Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp">

                <!-- Lingkaran kecil (Bisa pakai drawable shape oval) -->
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_circle_blue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Genre: Finance"
                    android:textSize="16sp"
                    android:textColor="#808080" />
            </LinearLayout>

            <!-- 2. Book Details Card (Biru Gelap) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#214467"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Book Details"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Garis pembatas (Divider) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:background="#40FFFFFF" />

                    <!-- 4 Kolom Info dengan layout_weight -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Item: Year -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Year" android:textColor="#B3FFFFFF" android:textSize="12sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2012" android:textColor="@android:color/white" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Item: Page -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Page" android:textColor="#B3FFFFFF" android:textSize="12sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="163" android:textColor="@android:color/white" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Item: Language -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Language" android:textColor="#B3FFFFFF" android:textSize="12sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="English" android:textColor="@android:color/white" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Item: Stock -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stock" android:textColor="#B3FFFFFF" android:textSize="12sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="32" android:textColor="@android:color/white" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. Synopsis Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:text="Synopsis"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Subtitle Synopsis pakai format yang sama kayak Genre di atas -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:text="A great supplemental text for the teaching of economics, this book offers a clear perspective..."
                android:textColor="#666666"
                android:lineSpacingExtra="4dp" />

            <!-- 4. Order Request Form Card -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:text="Order Request"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Card Form Order -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="40dp"
                app:cardBackgroundColor="#F2F0EB"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Address"
                        android:textStyle="bold"
                        android:textColor="@color/black" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_rounded"
                        android:hint="e.g Jalan Indonesia Raya..."
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Phone Number"
                        android:textStyle="bold"
                        android:textColor="@color/black" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_rounded"
                        android:hint="081234567890"
                        android:inputType="phone"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="24dp"
                        android:text="Order Now"
                        app:icon="@drawable/ic_cart"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        android:backgroundTint="#214467" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <ImageView
            android:id="@+id/imgBook"
            android:layout_width="120dp"
            android:layout_height="180dp"
            android:layout_marginEnd="32dp"
            android:elevation="20dp"
            android:background="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/blueHeader"
            app:layout_constraintBottom_toBottomOf="@id/blueHeader"
            app:layout_constraintVertical_bias="0.4"
            tools:ignore="ContentDescription" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</ScrollView>